# Frontend (Next.js) local development example
# Copy to .env for local non-docker runs, or use docker-compose.local.yml.

NEXT_PUBLIC_BACKEND_DOMAIN=http://localhost:5000
NEXT_PUBLIC_BETTER_AUTH_BASE_URL=http://localhost:5000

# Required by better-auth (pick any long random string for local)
BETTER_AUTH_SECRET=replace-me

# Database (shared docker Postgres)
# Note: Next.js migrations historically target the `public` schema.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/codecoliseum?schema=public

# Optional mail (leave empty for local)
GMAIL_USER=
GMAIL_APP_PASSWORD=
